{
  "name": "tele-quiz-bot",
  "version": "1.0.0",
  "description": "AI-powered Telegram trivia quiz bot with achievements and difficulty",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "pg": "^8.11.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.6.7",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "uvu": "^0.5.5",
    "vitest": "^1.6.1"
  }
}
